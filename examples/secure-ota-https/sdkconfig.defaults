# Target
CONFIG_IDF_TARGET="esp32s3"

# Flash — 16 MB Quad SPI NOR (ESP32-S3-WROOM-1-N16R8)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# Partition table — dual OTA layout (partitions.csv)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

# OTA rollback — new image must call esp_ota_mark_app_valid_cancel_rollback() on startup
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Safety
# Note: symbol is FREERTOS_CHECK_STACKOVERFLOW_CANARY (not ESP_SYSTEM_*) — see AIGenLessonsLearned.md
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_ESP_TASK_WDT_EN=y

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Serial console — native USB OTG only (no CH343P bridge on this board)
# Single port for both flash and monitor: idf.py -p /dev/cu.usbmodem2101 flash monitor
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
