menu "BLE Beacon Configuration"
    config EXAMPLE_LED_GPIO
        int "LED GPIO number"
        default 21
        range 0 48
        help
            GPIO of the onboard user LED.
            Overridden per-target via sdkconfig.defaults.<target>.
            S3 primary (YEJMKJ DevKitC)=48, S3 secondary (XIAO)=21,
            C6 primary (DevKitC)=8, C6 secondary (XIAO)=15, C5=27, ESP32=13.

    config EXAMPLE_LED_WS2812
        bool "Use WS2812 RGB LED (RMT-driven)"
        default n
        help
            When enabled, drives a WS2812 RGB LED via the RMT peripheral
            (GRB byte order, 10 MHz resolution). The LED is solid blue
            (0, 0, 64) while BLE advertising is active and off otherwise.
            Enable for boards with a WS2812 LED (YEJMKJ ESP32-S3-DevKitC-1-N16R8,
            Espressif ESP32-C6-DevKitC-1-N8) via sdkconfig.defaults.<target>.
            EXAMPLE_LED_ACTIVE_LEVEL is ignored when this symbol is enabled.

    config EXAMPLE_LED_ACTIVE_LEVEL
        int "LED active level (0=active-LOW, 1=active-HIGH)"
        default 0
        range 0 1
        depends on !EXAMPLE_LED_WS2812
        help
            Logic level that turns the GPIO LED ON.
            0=active LOW (XIAO boards, XIAO ESP32-C5), 1=active HIGH (HUZZAH32).
            Not used when EXAMPLE_LED_WS2812 is enabled.

    config EXAMPLE_BUTTON_GPIO
        int "Boot button GPIO number"
        depends on IDF_TARGET_ESP32 || IDF_TARGET_ESP32S3
        default 0
        range 0 48
        help
            GPIO of the active-LOW boot button used as deep-sleep wakeup source.
            Only available on targets where the boot button is an RTC-capable GPIO.
            ESP32-S3: GPIO 0 (RTC_GPIO0, ext1). ESP32: GPIO 0 (RTCIO_CH11, ext0).
            ESP32-C6/C5: boot button is GPIO 9, which is NOT RTC-capable on those
            targets (C6: only GPIO 0-7; C5: only GPIO 0-6). Timer-only wakeup is
            used on C6 and C5 — this symbol is not set for those targets.
