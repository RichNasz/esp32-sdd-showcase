# ---- BLE / NimBLE — broadcaster-only role ----
# NimBLE chosen over Bluedroid: ~50 ms init vs ~200 ms, ~30 KB RAM vs ~60 KB,
# and clean synchronous teardown via nimble_port_stop() — critical for 100 ms
# advertising windows followed by deep sleep.
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y

# Disable NimBLE security manager — required for broadcaster-only builds on ESP-IDF 5.5.x.
# Root cause (ESP-IDF bug): ble_hs.c calls ble_sm_deinit() when NIMBLE_BLE_SM=1, but
# ble_sm.c only defines ble_sm_deinit() when BLE_STATIC_TO_DYNAMIC=1 (default: 0).
# Guard mismatch → "undefined reference to ble_sm_deinit" at link time.
# Fix: SECURITY_ENABLE=n → BLE_SM_LEGACY=0 + BLE_SM_SC=0 → NIMBLE_BLE_SM=0 →
# ble_hs.c skips ble_sm_deinit() call → link succeeds.
# See AIGenLessonsLearned.md for full analysis. (Mar 2026)
CONFIG_BT_NIMBLE_SECURITY_ENABLE=n

# Stack size: 4096 minimum per ble-patterns.md gotchas
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=4096

# ---- Deep sleep power savings ----
# Power down flash during sleep — safe when no RTC wake stub accesses flash
CONFIG_ESP_SLEEP_POWER_DOWN_FLASH=y

# ---- Safety ----
# Correct symbol name for ESP-IDF 5.x — see AIGenLessonsLearned.md
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_ESP_TASK_WDT_EN=y

# ---- Logging ----
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
